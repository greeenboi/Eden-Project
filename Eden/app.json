{
  "expo": {
    "name": "Eden",
    "slug": "Eden",
    "version": "2.1.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "eden",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#180518",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#180518"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#180518"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.greenarcade.Eden"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#180518",
          "image": "./assets/images/splash-icon.png",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#180518"
          },
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      "expo-audio",
      "expo-font",
      "expo-web-browser",
      "expo-mail-composer",
      "expo-build-properties",
      [
        "expo-notifications",
        {
          "color": "#180518",
          "defaultChannel": "media-playback"
        }
      ],
      "expo-image",
      "@rnrepo/expo-config-plugin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7c8fdf56-1fbf-4789-8ec8-c4ef1ac987a4"
      }
    },
    "owner": "greenarcade"
  }
}
