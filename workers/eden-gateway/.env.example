# Redis connection (choose one):
# Full URL (preferred). Use rediss:// for TLS.
REDIS_URL=redis://localhost:6379

# Or host/port credentials (ignored if REDIS_URL is set)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_TLS=false

# Queue name override (defaults to "downloader")
# DOWNLOADER_QUEUE_NAME=downloader

# Downloader service (if the gateway also POSTs directly to the worker)
# DOWNLOADER_SERVICE_URL=https://eden-downloader-worker.example.com
# DOWNLOADER_SERVICE_API_KEY=change-me
# Optional path override if your worker uses a different route
# DOWNLOADER_SERVICE_PATH=/youtube-to-ogg
